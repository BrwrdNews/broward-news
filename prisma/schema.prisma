generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Story
// ---------------------------------------------------------------------------

model Story {
  id                    String             @id @default(cuid())
  slug                  String             @unique
  headline_standard     String
  headline_catchy       String
  headline_chosen       String?
  editorial_tone        String             @default("Catchy tabloid-style, fact-bound, legally cautious.")
  geography_focus       String             @default("Fort Lauderdale / Broward County, Florida")
  source_confidence_score Float            @default(0.0)
  body                  String             @db.Text
  status                StoryStatus        @default(DRAFT)
  source_name           String
  source_url            String?
  incident_date         DateTime?
  arrest_date           DateTime?
  subject_name          String?
  /// "man" | "woman" | "resident" | "suspect" — used as descriptor in generated headlines
  subject_descriptor    String             @default("resident")
  charges               String[]
  booking_number        String?
  municipality          String?
  /// Detected from charge text; controls neutral-only headline mode
  sensitive_category    SensitiveCategory?
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt
  published_at          DateTime?
  reviewed_by           String?
  reviewed_at           DateTime?
  admin_notes           String?            @db.Text

  headlines             StoryHeadline[]
  notifications         HeadlineNotification[]

  @@index([status])
  @@index([created_at])
  @@index([municipality])
}

// ---------------------------------------------------------------------------
// StoryHeadline — one row per generated headline option
// ---------------------------------------------------------------------------

model StoryHeadline {
  id                    String          @id @default(cuid())
  story_id              String
  story                 Story           @relation(fields: [story_id], references: [id], onDelete: Cascade)

  headline_text         String
  headline_type         HeadlineType
  factual_safety_score  Int             /// 1–10
  catchiness_score      Int             /// 1–10
  risk_level            RiskLevel
  reason_for_score      String          @db.Text
  source_fields_used    String[]

  /// Approval workflow status — independent of story publish status
  approval_status       HeadlineStatus  @default(PENDING)
  approved_by           String?         /// admin user id
  approved_at           DateTime?
  rejection_reason      String?

  is_selected           Boolean         @default(false)
  is_blocked            Boolean         @default(false)
  generation_batch      Int             @default(1)

  created_at            DateTime        @default(now())

  @@index([story_id])
  @@index([is_selected])
  @@index([approval_status])
  @@index([story_id, generation_batch])
}

// ---------------------------------------------------------------------------
// HeadlineNotification — tracks in-app and email alerts per story batch
// ---------------------------------------------------------------------------

model HeadlineNotification {
  id           String               @id @default(cuid())
  story_id     String
  story        Story                @relation(fields: [story_id], references: [id], onDelete: Cascade)
  batch        Int
  type         NotificationType     @default(BATCH_READY)
  sent_at      DateTime             @default(now())
  dismissed_at DateTime?
  email_sent   Boolean              @default(false)
  email_error  String?

  @@index([story_id])
  @@index([dismissed_at])
}

// ---------------------------------------------------------------------------
// Admin users
// ---------------------------------------------------------------------------

model AdminUser {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  name       String
  created_at DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum StoryStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  PUBLISHED
  REJECTED
}

enum HeadlineType {
  STANDARD
  CATCHY
  ALLITERATIVE
  RHYME
  IDIOM
  SHORT_MOBILE
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

/// Per-headline approval mini-workflow
enum HeadlineStatus {
  PENDING    /// generated, not yet reviewed
  APPROVED   /// admin approved — eligible for selection
  REJECTED   /// admin rejected — not selectable
}

enum NotificationType {
  BATCH_READY    /// new batch generated, needs admin review
  NEEDS_HEADLINE /// story approaching publish but no headline selected
}

/// When set, only neutral headline types are generated and only LOW-risk
/// headlines are selectable without additional confirmation.
enum SensitiveCategory {
  SEX_CRIME
  DOMESTIC_VIOLENCE
  MINOR_INVOLVED
  DEATH
  SERIOUS_INJURY
  HUMAN_TRAFFICKING
  HATE_CRIME
  MENTAL_HEALTH
}
